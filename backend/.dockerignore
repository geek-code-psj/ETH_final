# .dockerignore — exclude files from Docker build context

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/

# Virtual env
venv/
env/
.venv/
.env/

# Local env file (NEVER send to Docker)
.env
.env.local
.env.*.local

# Alembic history (migrated at runtime)
alembic/versions/*.py

# Test / dev files
tests/
test_*.py
*_test.py

# IDE
.vscode/
.idea/
*.swp

# Git
.git/
.gitignore

# Logs
*.log
logs/

# SQLite test files
*.db
