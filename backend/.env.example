# ─────────────────────────────────────────────────────────────────────────────
# .env.example  — Copy this to .env and fill in your real values
# NEVER commit the real .env file to Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local (SQLite for quick testing, no PostgreSQL needed)
DATABASE_URL=sqlite:///./hrms_local.db

# Production (Render PostgreSQL — get from Render dashboard)
# DATABASE_URL=postgresql://hrms_user:hrms_pass@host/hrms_db

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
DEV_MODE=true
FRONTEND_URL=http://localhost:5173

# ── Firebase Admin (for admin login) ─────────────────────────────────────────
# Paste the full JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Employee Portal JWT ───────────────────────────────────────────────────────
EMPLOYEE_JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Cloudinary (document uploads) — optional ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SendGrid (email notifications) — optional ────────────────────────────────
SENDGRID_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@yourcompany.com

# ── Sentry (error tracking) — optional ───────────────────────────────────────
SENTRY_DSN=
